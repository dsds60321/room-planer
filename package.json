{
  "name": "room-planner",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "dev:local": "dotenv -e .env.local -- next dev",
    "dev:prod": "dotenv -e .env.production -- next dev",
    "build": "next build",
    "build:local": "dotenv -e .env.local -- next build",
    "build:prod": "dotenv -e .env.production -- next build",
    "prepare:standalone": "node scripts/prepare-standalone.mjs",
    "build:standalone": "npm run build && npm run prepare:standalone",
    "build:local:standalone": "npm run build:local && npm run prepare:standalone",
    "build:prod:standalone": "npm run build:prod && npm run prepare:standalone",
    "start": "next start",
    "start:local": "dotenv -e .env.local -- next start",
    "start:prod": "dotenv -e .env.production -- next start",
    "start:standalone": "node .next/standalone/server.js",
    "lint": "eslint"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@tanstack/react-query": "^5.95.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "konva": "^10.2.3",
    "lucide-react": "^0.577.0",
    "mysql2": "^3.20.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.0",
    "react-konva": "^19.2.3",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
